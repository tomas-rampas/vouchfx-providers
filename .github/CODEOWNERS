# CODEOWNERS — require maintainer review for registry changes, community
# submissions, and any governance or CI/CD file.
#
# Rules are evaluated last-match-wins (bottom of file wins), so the specific
# path overrides below the catch-all are intentionally listed after it.
#
# See: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Catch-all: every file requires at least one maintainer approval.
*                    @tomas-rampas

# Community-tier source submissions — a maintainer gates the INITIAL merge
# (licence/DCO/namespace hygiene/conformance only — not a code review; hosting
# is not endorsement). When a submission merges, append a line here giving the
# author ownership of their folder, e.g.:
#   /community/Community.Steps.Foo/  @their-github-handle
/community/          @tomas-rampas

# Registry index — controls what is publicly discoverable. This also gates
# Vouched badge awards: a PR setting "vouched": true on an entry may only
# merge with maintainer approval.
/registry/           @tomas-rampas

# Governance and CI/CD changes — workflows, templates, CODEOWNERS, labels.
/.github/            @tomas-rampas
