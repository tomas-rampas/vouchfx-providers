<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed for packages not resolved from nuget.org. The published SDK itself
         restores from nuget.org at the pinned $(VouchfxSdkVersion) (see
         Directory.Build.props) — this feed is no longer that path's source. What packs
         here now is the optional engine-main override: Vouchfx.Sdk / Vouchfx.Sdk.Testing
         (and their Vouchfx.Engine.* transitive closure) built from the engine's unreleased
         main branch, for CI's engine-main early-warning lane and advanced local work (see
         CONTRIBUTING.md "Building against engine main (optional)"). The folder is kept via
         packages-local/.gitkeep so this source path always resolves; the .nupkg artifacts
         themselves are git-ignored. -->
    <add key="local" value="packages-local" />
  </packageSources>
  <!-- packageSourceMapping prevents dependency-confusion attacks.
       PRECONDITION: this dual-feed mapping is safe only once the engine has published
       AND owns the vouchfx* IDs on nuget.org; before that, nuget.org resolution for
       this prefix is a dependency-confusion window (the previous exclusive-local
       mapping was immune to it) — an unowned ID could be squatted by an attacker at
       any version and win the restore. Do not rely on this mapping until ownership is
       verified. As of the engine's v1.0.0-alpha.4 release (first publish of the
       Vouchfx.* package IDs after the Platform.*-to-Vouchfx.* namespace rebrand,
       engine PR #193), the engine legitimately owns and publishes these IDs, so this
       precondition is satisfied — see RELEASING.md in the engine repo for the
       unlist/deprecate runbook for the six retired Platform.* IDs.
       Once that precondition holds, the two feeds serve distinct roles: nuget.org
       resolves the published SDK at the pinned $(VouchfxSdkVersion), and local resolves
       the optional engine-main override builds (see Directory.Build.props and
       CONTRIBUTING.md "Building against engine main (optional)"). Either way, the
       mapping's job is confining vouchfx* resolution to exactly these two feeds —
       restore must never pull that prefix from any third source. A single "vouchfx*"
       pattern is sufficient for both the engine's own IDs (Vouchfx.Sdk,
       Vouchfx.Engine.*) and the hub's own community-provider IDs
       (Vouchfx.Community.*): packageSourceMapping glob patterns are matched
       case-insensitively, so "vouchfx*" already matches every "Vouchfx.*" package id —
       no separate "Platform.*" pattern is needed or kept. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="vouchfx*" />
    </packageSource>
    <packageSource key="local">
      <package pattern="vouchfx*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
