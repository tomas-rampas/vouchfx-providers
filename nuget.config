<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed for packages not resolved from nuget.org. The published SDK itself
         restores from nuget.org at the pinned $(VouchfxSdkVersion) (see
         Directory.Build.props) — this feed is no longer that path's source. What packs
         here now is the optional engine-main override: Platform.Sdk / Platform.Sdk.Testing
         (and their Platform.Engine.* transitive closure) built from the engine's unreleased
         main branch, for CI's engine-main early-warning lane and advanced local work (see
         CONTRIBUTING.md "Building against engine main (optional)"). The folder is kept via
         packages-local/.gitkeep so this source path always resolves; the .nupkg artifacts
         themselves are git-ignored. -->
    <add key="local" value="packages-local" />
  </packageSources>
  <!-- packageSourceMapping prevents dependency-confusion attacks.
       PRECONDITION: this dual-feed mapping is safe only once the engine has published
       AND owns the Platform.*/vouchfx* IDs on nuget.org; before that, nuget.org
       resolution for these prefixes is a dependency-confusion window (the previous
       exclusive-local mapping was immune to it) — an unowned ID could be squatted by an
       attacker at any version and win the restore. Do not rely on this mapping until
       ownership is verified.
       Once that precondition holds, the two feeds serve distinct roles: nuget.org
       resolves the published SDK at the pinned $(VouchfxSdkVersion), and local resolves
       the optional engine-main override builds (see Directory.Build.props and
       CONTRIBUTING.md "Building against engine main (optional)"). Either way, the
       mapping's job is confining Platform.*/vouchfx* resolution to exactly these two
       feeds — restore must never pull those prefixes from any third source. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Platform.*" />
      <package pattern="vouchfx*" />
    </packageSource>
    <packageSource key="local">
      <package pattern="Platform.*" />
      <package pattern="vouchfx*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
