<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local pre-release feed for Platform.Sdk / Platform.Sdk.Testing. These ship to
         nuget.org with the vouchfx v1.0 release (S12-D-01); until then, pack them from the
         engine into packages-local/ (see CONTRIBUTING.md "Building before v1.0"). The folder
         is kept via packages-local/.gitkeep so this source path always resolves; the .nupkg
         artifacts themselves are git-ignored. -->
    <add key="local" value="packages-local" />
  </packageSources>
  <!-- packageSourceMapping prevents dependency-confusion attacks.
       Pre-publication, Platform.* / vouchfx* were internal packages not yet on
       nuget.org, so this mapping's whole job was pinning those IDs to the local feed
       (packages-local/) — the only defence against an attacker squatting the IDs on
       nuget.org and winning the restore.
       Now that the SDK closure ships to nuget.org with the tagged engine release,
       the primary defence is ownership: those IDs are registered under this project's
       nuget.org account, so nobody else can publish under them. The mapping's
       remaining job is confining Platform.*/vouchfx* resolution to exactly these two
       feeds — nuget.org (the published packages) and local (the pre-publication /
       engine-main early-warning packages, see Directory.Build.props) — so restore can
       never pull those prefixes from any third source. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Platform.*" />
      <package pattern="vouchfx*" />
    </packageSource>
    <packageSource key="local">
      <package pattern="Platform.*" />
      <package pattern="vouchfx*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
